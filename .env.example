# These are auto-injected by Vercel when you connect Neon Postgres in Storage tab
# For local development, copy values from .env.local (generated by `vercel env pull`)
POSTGRES_PRISMA_URL="postgresql://user:pass@ep-xxx.neon.tech/neondb?channel_binding=require&connect_timeout=15&sslmode=require"
POSTGRES_URL_NON_POOLING="postgresql://user:pass@ep-xxx.neon.tech/neondb?channel_binding=require&sslmode=require"

# NextAuth - Set manually in Vercel Dashboard → Settings → Environment Variables
NEXTAUTH_SECRET="generate-a-random-secret-key"
NEXTAUTH_URL="https://your-app.vercel.app"

# Google OAuth (optional - for Google sign-in)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
