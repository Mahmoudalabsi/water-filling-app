# Vercel Postgres (Neon) - These are auto-injected when you connect Postgres in Vercel Dashboard → Storage
# For local development, copy values from Vercel Dashboard → Storage → Postgres → .env.local tab
POSTGRES_PRISMA_URL="postgresql://user:pass@ep-xxx.neon.tech/verceldb?sslmode=require&pgbouncer=true&connect_timeout=10"
POSTGRES_URL_NON_POOLING="postgresql://user:pass@ep-xxx.neon.tech/verceldb?sslmode=require"

# NextAuth - You must set these manually in Vercel Dashboard → Settings → Environment Variables
NEXTAUTH_SECRET="generate-a-random-secret-key"
NEXTAUTH_URL="https://your-app.vercel.app"

# Google OAuth (optional - for Google sign-in)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
