# For Vercel Postgres (Neon) deployment
# Get these from: Vercel Dashboard → Storage → Postgres → .env.local tab

# POSTGRES_PRISMA_URL (pooled connection - for app queries)
DATABASE_URL=postgresql://default:YOUR_PASSWORD@ep-HOSTNAME.us-east-2.aws.neon.tech/verceldb?sslmode=require&pgbouncer=true

# POSTGRES_URL_NON_POOLING (direct connection - for migrations)
DIRECT_URL=postgresql://default:YOUR_PASSWORD@ep-HOSTNAME.us-east-2.aws.neon.tech/verceldb?sslmode=require

NEXTAUTH_SECRET=your-secret-key-here-change-in-production
NEXTAUTH_URL=https://your-app.vercel.app
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
